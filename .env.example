# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=notifyhub
MYSQL_USER=notifyhub
MYSQL_PASSWORD=

# Connection string used by api/worker (Pomelo MySql format)
CONNECTIONSTRINGS__DEFAULT=Server=mysql;Port=3306;Database=notifyhub;User=notifyhub;Password=CHANGE_ME;

# JWT
JWT__SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT__ACCESSTOKENMINUTES=30
JWT__REFRESHTOKENDAYS=7

# CORS
CORS__WEBORIGIN=http://localhost:5173

# Seed accounts (must satisfy password policy: min 8 chars, upper/lower/number/symbol)
SEED__ADMINUSERNAME=admin
SEED__ADMINPASSWORD=CHANGE_ME
SEED__STAFFUSERNAME=staff
SEED__STAFFPASSWORD=CHANGE_ME

# Mock gateway
MOCKGATEWAY__FAILRATEPERCENT=10
MOCKGATEWAY__MINDELAYMS=100
MOCKGATEWAY__MAXDELAYMS=1000
# Api's own self-callback (posts its simulated delivery receipt back to its own webhook)
MOCKGATEWAY__CALLBACKBASEURL=http://localhost:5000
# Worker -> Api, over the docker-compose network
MOCKGATEWAY__APIBASEURL=http://api:5000

# Webhook shared secret (also used to authenticate Worker -> Api mock-gateway calls)
WEBHOOKS__SHAREDSECRET=CHANGE_ME

# Frontend
VITE_API_URL=http://localhost:5000
